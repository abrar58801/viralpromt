<%- include('partials/header') %>

    <div class="min-h-screen bg-black text-white">

        <!-- Hero -->
        <section class="max-w-5xl mx-auto px-4 py-20 text-center">

            <div
                class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-xs font-black tracking-[3px] uppercase mb-8">

                📘 User Guide

            </div>

            <h1 class="text-5xl md:text-7xl font-black leading-tight mb-6">

                How To
                <span class="text-cyan-400">
                    Use Prompts
                </span>

            </h1>

            <p class="text-gray-400 max-w-2xl mx-auto leading-8">

                Learn how to unlock, copy,
                and use premium AI prompts
                to create viral content.

            </p>

        </section>

        <!-- Content -->
        <section class="max-w-5xl mx-auto px-4 pb-20">

            <div class="bg-[#111] border border-white/5 rounded-[32px] p-6 md:p-10">

                <!-- Dynamic Content -->
                <div class="space-y-6 text-gray-300 leading-8 text-lg">

                    <% if(settings.how_to_use) { %>

                        <% const steps=settings.how_to_use .split('\n') .filter( step=> step.trim()
                            );
                            %>

                            <% steps.forEach((step, index)=> { %>

                                <div
                                    class="flex items-start gap-5 bg-white/[0.02] border border-white/5 rounded-3xl p-6 hover:border-cyan-500/20 transition-all">

                                    <!-- Number -->
                                    <div
                                        class="min-w-[55px] h-[55px] rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 font-black text-xl">

                                        <%= index + 1 %>

                                    </div>

                                    <!-- Text -->
                                    <div>

                                        <h3 class="text-xl font-bold text-white mb-2">

                                            Step
                                            <%= index + 1 %>

                                        </h3>

                                        <p class="text-gray-400 leading-8">

                                            <%= step %>

                                        </p>

                                    </div>

                                </div>

                                <% }) %>

                                    <% } else { %>

                                        <!-- Default -->
                                        <div class="space-y-6">

                                            <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-6">

                                                1. Register account

                                            </div>

                                            <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-6">

                                                2. Add credits

                                            </div>

                                            <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-6">

                                                3. Unlock prompt

                                            </div>

                                            <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-6">

                                                4. Copy & use prompt

                                            </div>

                                        </div>

                                        <% } %>

                </div>

            </div>

        </section>

    </div>

    <%- include('partials/footer') %>