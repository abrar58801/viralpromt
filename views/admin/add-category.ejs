<%- include('header') %>

<div class="flex flex-col md:flex-row min-h-screen bg-black">
    <%- include('sidebar') %>

    <main class="flex-1 p-6 md:p-10">

        <div class="flex justify-between items-center mb-8">
            <h1 class="text-2xl font-bold text-white uppercase">
                Add <span class="text-red-500">Category</span>
            </h1>

            <a href="/admin/categories"
                class="border border-white/10 px-6 py-3 rounded-2xl font-bold uppercase">
                ← Back
            </a>
        </div>

        <div class="bg-[#111] p-8 border border-white/5 rounded-2xl">
            <form action="/admin/add-category" method="POST" class="space-y-6">

                <input
                    type="text"
                    name="name"
                    placeholder="Category Name"
                    required
                    class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white">

                <select
                    name="status"
                    class="w-full bg-white/5 border border-white/10 p-4 rounded-xl text-white">

                    <option value="1">Active</option>
                    <option value="0">Inactive</option>

                </select>

                <button
                    type="submit"
                    class="w-full bg-red-600 hover:bg-red-700 py-4 rounded-xl font-bold uppercase">
                    Add Category
                </button>

            </form>
        </div>

    </main>
</div>
