<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- SEO -->
    <title>

        <%= settings.site_title || 'VIRAL PROMPT' %>

    </title>

    <meta name="description" content="<%= settings.site_description || '' %>">

    <meta name="keywords" content="<%= settings.seo_tags || '' %>">

    <!-- Open Graph -->
    <meta property="og:title" content="<%= settings.site_title || 'VIRAL PROMPT' %>">

    <meta property="og:description" content="<%= settings.site_description || '' %>">

    <meta property="og:image" content="/uploads/<%= settings.header_logo || '' %>">

    <!-- Twitter -->
    <meta name="twitter:title" content="<%= settings.site_title || 'VIRAL PROMPT' %>">

    <meta name="twitter:description" content="<%= settings.site_description || '' %>">

    <meta name="twitter:image" content="/uploads/<%= settings.header_logo || '' %>">

    <!-- Favicon -->
    <link rel="icon" href="/uploads/<%= settings.header_logo || '' %>">

    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>

<body class="bg-black">
    <nav class="nav-header sticky top-0 z-50">

        <!-- Logo -->
        <div class="logo font-extrabold text-2xl text-cyan-400">
            <a href="/">
                <img src="/uploads/<%= settings.header_logo %>" class="user_site_logo">
            </a>
        </div>

        <!-- Desktop Menu -->
        <div class="menu space-x-6 hidden md:flex items-center">

            <a href="/" class="hover:text-cyan-400 transition">
                Home
            </a>

            <a href="/about" class="hover:text-cyan-400 transition">
                About
            </a>

            <a href="/contact" class="hover:text-cyan-400 transition">
                Contact
            </a>

            <a href="/how-to-use" class="hover:text-cyan-400 transition">
                How To Use
            </a>

            <a href="/refer-earn" class="hover:text-cyan-400 transition">
                Refer & Earn
            </a>

        </div>

        <!-- Right -->
        <div class="flex items-center gap-3">

            <% if (typeof user !=='undefined' && user) { %>

                <!-- User Dropdown -->
                <div class="relative group hidden md:block">

                    <!-- Profile Button -->
                    <button
                        class="flex items-center gap-2 border border-white/20 rounded-full bg-white/5 hover:bg-white/10 transition profile_btn px-4 py-2">

                        <span class="text-cyan-400">
                            🪙 <%= user.wallet_credits || 0 %>
                        </span>

                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>

                    </button>

                    <!-- Dropdown -->
                    <div
                        class="absolute right-0 mt-3 w-56 bg-[#111] border border-white/10 rounded-2xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden">

                        <div class="px-4 py-3 border-b border-white/10">

                            <p class="text-sm font-semibold text-white">
                                <%= user.full_name || 'User' %>
                            </p>

                            <p class="text-xs text-gray-400 truncate">
                                <%= user.email || '' %>
                            </p>

                        </div>

                        <a href="/dashboard"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">

                            🏠 Dashboard
                        </a>

                        <a href="/add-fund"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">

                            💰 Add Fund
                        </a>

                        <a href="/withdraw"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">
                            💸 Withdraw
                        </a>

                        <a href="/transactions"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">

                            🔀 Transactions
                        </a>

                        <a href="/my-unlocks"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">

                            🔓 My Unlocks
                        </a>

                        <a href="/change-password"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">
                            🔐 Change Password
                        </a>

                        <a href="/refer-earn"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">

                            🎁 Refer & Earn
                        </a>

                        <a href="/support"
                            class="flex items-center px-4 py-3 text-sm hover:bg-cyan-400/10 hover:text-cyan-400 transition">

                            📞 Support
                        </a>

                        <div class="border-t border-white/10"></div>

                        <a href="/logout"
                            class="flex items-center px-4 py-3 text-sm text-red-400 hover:bg-red-500/10 transition">

                            🔓 Logout
                        </a>

                    </div>

                </div>

                <% } else { %>

                    <!-- Desktop Auth -->
                    <div class="hidden md:flex items-center gap-3">

                        <a href="/login"
                            class="text-sm border border-white/30 px-4 py-2 rounded-full hover:border-cyan-400 hover:text-cyan-400 transition">

                            Login
                        </a>

                        <a href="/register" class="btn-neon text-sm">
                            Join Now
                        </a>

                    </div>

                    <% } %>

                        <!-- Mobile Toggle -->
                        <button id="mobileMenuBtn"
                            class="md:hidden w-11 h-11 flex items-center justify-center rounded-xl border border-white/10 bg-white/5">
                            ☰
                        </button>

        </div>

    </nav>

    <!-- Mobile Menu -->
    <div id="mobileMenu"
        class="hidden md:hidden fixed top-[78px] left-0 w-full bg-black/95 backdrop-blur-xl border-t border-white/10 z-50">

        <div class="flex flex-col p-6 space-y-4">

            <a href="/" class="mobile-link">
                🏠 Home
            </a>

            <a href="/about" class="mobile-link">
                ℹ️ About
            </a>

            <% if (!user) { %>
                <a href="/contact" class="mobile-link">
                    📞 Contact
                </a>

                <a href="/refer-earn" class="mobile-link">
                    🎁 Refer & Earn
                </a>
                <% } %>

                    <a href="/how-to-use" class="mobile-link">
                        📘 How To Use
                    </a>

                    <% if (typeof user !=='undefined' && user) { %>

                        <div class="border-t border-white/10 pt-4">

                            <div class="mb-4">

                                <p class="text-cyan-400 font-bold">
                                    <%= user.full_name %>
                                </p>

                                <p class="text-gray-400">
                                    🪙 <%= user.wallet_credits %> Credits
                                </p>

                            </div>

                            <div class="flex flex-col gap-3">

                                <a href="/dashboard" class="mobile-link">
                                    🏠 Dashboard
                                </a>

                                <a href="/add-fund" class="mobile-link">
                                    💰 Add Fund
                                </a>

                                <a href="/withdraw" class="mobile-link">
                                    💸 Withdraw
                                </a>

                                <a href="/transactions" class="mobile-link">
                                    🔀 Transactions
                                </a>

                                <a href="/my-unlocks" class="mobile-link">
                                    🔓 My Unlocks
                                </a>

                                <a href="/change-password" class="mobile-link">
                                    🔐 Change Password
                                </a>

                                <a href="/refer-earn" class="mobile-link">
                                    🎁 Refer & Earn
                                </a>

                                <a href="/support" class="mobile-link">
                                    📞 Support
                                </a>

                                <a href="/logout" class="mobile-link text-red-400">
                                    🔓 Logout
                                </a>

                            </div>

                        </div>

                        <% } else { %>

                            <div class="border-t border-white/10 pt-4 flex flex-col gap-4">

                                <a href="/login" class="text-center border border-white/20 rounded-xl py-3">

                                    Login
                                </a>

                                <a href="/register" class="btn-neon text-center py-3">

                                    Join Now
                                </a>

                            </div>

                            <% } %>

        </div>

    </div>

    <script id="p4m8vx">

        const mobileMenuBtn = document.getElementById('mobileMenuBtn');

        const mobileMenu = document.getElementById('mobileMenu');

        mobileMenuBtn.addEventListener('click', () => {

            mobileMenu.classList.toggle('hidden');

        });

    </script>