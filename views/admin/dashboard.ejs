<%- include('header') %>

    <div class="flex flex-col md:flex-row min-h-screen bg-black text-white">

        <!-- Sidebar -->
        <%- include('sidebar') %>

            <!-- Main -->
            <main class="flex-1 p-6 md:p-10">

                <!-- Top -->
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-10">

                    <div>

                        <h1 class="text-3xl font-black">

                            Admin
                            <span class="text-red-500">
                                Dashboard
                            </span>

                        </h1>

                        <p class="text-gray-500 mt-2">

                            Complete system overview
                            and analytics.

                        </p>

                    </div>

                    <div
                        class="bg-green-500/10 border border-green-500/20 text-green-400 px-5 py-3 rounded-2xl text-sm font-bold">

                        ● System Online

                    </div>

                </div>

                <!-- Stats -->
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-10">

                    <!-- Today Register -->
                    <div class="glass-card p-6 border border-cyan-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Today Register

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-cyan-400">

                            <%= todayRegister %>

                        </h2>

                    </div>

                    <!-- Total Register -->
                    <div class="glass-card p-6 border border-blue-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Total Registered

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-blue-400">

                            <%= totalRegister %>

                        </h2>

                    </div>

                    <!-- Today Deposit -->
                    <div class="glass-card p-6 border border-green-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Today Deposit

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-green-400">

                            ₹<%= todayDeposit %>

                        </h2>

                    </div>

                    <!-- Total Deposit -->
                    <div class="glass-card p-6 border border-yellow-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Total Deposit

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-yellow-400">

                            ₹<%= totalDeposit %>

                        </h2>

                    </div>

                    <div class="glass-card p-6 border border-orange-500/10">
                        <p class="text-xs text-gray-400 uppercase tracking-widest">
                            Pending Deposit
                        </p>

                        <h2 class="text-4xl font-black mt-3 text-orange-400">
                            <%= pendingPayments %>
                        </h2>
                    </div>

                    <!-- Today Withdraw -->
                    <div class="glass-card p-6 border border-red-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Today Withdraw

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-red-400">

                            ₹<%= todayWithdraw %>

                        </h2>

                    </div>

                    <!-- Total Withdraw -->
                    <div class="glass-card p-6 border border-orange-500/10">
                        <p class="text-xs text-gray-400 uppercase tracking-widest">
                            Total Withdraw
                        </p>

                        <h2 class="text-4xl font-black mt-3 text-orange-400">
                            ₹<%= totalWithdraw %>
                        </h2>
                    </div>

                    <div class="glass-card p-6 border border-orange-500/10">
                        <p class="text-xs text-gray-400 uppercase tracking-widest">
                            Pending Withdraw
                        </p>

                        <h2 class="text-4xl font-black mt-3 text-orange-400">
                            <%= pendingWithdraw %>
                        </h2>
                    </div>

                    <!-- Today Unlock -->
                    <div class="glass-card p-6 border border-purple-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Today Unlock

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-purple-400">

                            <%= todayUnlock %>

                        </h2>

                    </div>

                    <!-- Total Unlock -->
                    <div class="glass-card p-6 border border-pink-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Total Unlock

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-pink-400">

                            <%= totalUnlock %>

                        </h2>

                    </div>

                    <!-- Available Credit -->
                    <div class="glass-card p-6 border border-orange-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Available Credit

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-orange-400">

                            🪙 <%= availableCredit %>

                        </h2>

                    </div>

                    <!-- Used Credit -->
                    <div class="glass-card p-6 border border-red-500/10">

                        <p class="text-xs text-gray-400 uppercase tracking-widest">

                            Used Credit

                        </p>

                        <h2 class="text-4xl font-black mt-3 text-red-400">

                            🪙 <%= usedCredit %>

                        </h2>

                    </div>

                </div>

                <!-- Quick Actions -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

                    <!-- Actions -->
                    <div class="glass-card p-8">

                        <h3 class="font-bold text-lg mb-6">

                            ⚡ Quick Actions

                        </h3>

                        <div class="grid grid-cols-2 gap-4">

                            <a href="/admin/add-prompt"
                                class="bg-white/5 hover:bg-red-500/10 border border-white/10 hover:border-red-500/30 rounded-2xl p-5 text-center transition">

                                <div class="text-3xl mb-3">
                                    ➕
                                </div>

                                <p class="text-sm font-semibold">

                                    Add Prompt

                                </p>

                            </a>

                            <a href="/admin/prompts"
                                class="bg-white/5 hover:bg-red-500/10 border border-white/10 hover:border-red-500/30 rounded-2xl p-5 text-center transition">

                                <div class="text-3xl mb-3">
                                    📝
                                </div>

                                <p class="text-sm font-semibold">

                                    Manage Prompts

                                </p>

                            </a>

                            <a href="/admin/users"
                                class="bg-white/5 hover:bg-red-500/10 border border-white/10 hover:border-red-500/30 rounded-2xl p-5 text-center transition">

                                <div class="text-3xl mb-3">
                                    👥
                                </div>

                                <p class="text-sm font-semibold">

                                    Manage Users

                                </p>

                            </a>

                            <a href="/admin/settings"
                                class="bg-white/5 hover:bg-red-500/10 border border-white/10 hover:border-red-500/30 rounded-2xl p-5 text-center transition">

                                <div class="text-3xl mb-3">
                                    ⚙️
                                </div>

                                <p class="text-sm font-semibold">

                                    Site Settings

                                </p>

                            </a>

                        </div>

                    </div>

                    <!-- System Info -->
                    <div class="glass-card p-8">

                        <h3 class="font-bold text-lg mb-6">

                            📡 System Information

                        </h3>

                        <div class="space-y-5">

                            <div class="flex items-center justify-between border-b border-white/5 pb-4">

                                <span class="text-gray-400">
                                    Website Status
                                </span>

                                <span class="text-green-400 font-bold">
                                    Online
                                </span>

                            </div>

                            <div class="flex items-center justify-between border-b border-white/5 pb-4">

                                <span class="text-gray-400">
                                    Total Prompts
                                </span>

                                <span class="font-bold">
                                    <%= totalPrompts %>
                                </span>

                            </div>

                            <div class="flex items-center justify-between border-b border-white/5 pb-4">

                                <span class="text-gray-400">
                                    Pending Deposits
                                </span>

                                <span class="text-yellow-400 font-bold">
                                    <%= pendingPayments %>
                                </span>

                            </div>

                            <div class="flex items-center justify-between border-b border-white/5 pb-4">

                                <span class="text-gray-400">
                                    Pending Withdrawals
                                </span>

                                <span class="text-red-400 font-bold">
                                    <%= pendingWithdraw %>
                                </span>

                            </div>

                            <div class="flex items-center justify-between">

                                <span class="text-gray-400">
                                    Contact Messages
                                </span>

                                <span class="text-cyan-400 font-bold">
                                    <%= totalMessages %>
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

            </main>

    </div>