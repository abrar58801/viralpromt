<%- include('header') %>

    <div class="flex flex-col md:flex-row min-h-screen bg-black">

        <%- include('sidebar') %>

            <main class="flex-1 p-6 md:p-10">

                <!-- Header -->
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">

                    <div>

                        <h1 class="text-2xl font-bold text-white uppercase tracking-tighter">
                            Manage
                            <span class="text-red-500">
                                Users
                            </span>
                        </h1>

                    </div>

                </div>

                <!-- Search -->
                <form method="GET" class="mb-8">

                    <div class="relative">

                        <!-- Input -->
                        <input type="text" name="search" value="<%= search %>" placeholder="Search user..."
                            class="w-full bg-[#111] border border-white/10 rounded-2xl px-6 py-4 pr-36 text-white outline-none focus:border-red-500 transition-all">

                        <!-- Button -->
                        <button type="submit"
                            class="absolute top-1/2 right-3 -translate-y-1/2 bg-red-600 hover:bg-red-700 px-6 py-2 rounded-xl text-sm font-bold uppercase tracking-widest transition-all">

                            Search
                        </button>

                    </div>

                </form>

                <!-- Table -->
                <div class="bg-[#111] rounded-2xl border border-white/5 overflow-hidden">

                    <div class="overflow-x-auto">

                        <table class="w-full">
                            <thead class="bg-white/5 text-[10px] uppercase text-gray-500 tracking-widest">

                                <tr>

                                    <th class="p-5 text-left">
                                        User
                                    </th>

                                    <th class="p-5 text-left">
                                        Mobile
                                    </th>

                                    <th class="p-5 text-left">
                                        Email
                                    </th>

                                    <th class="p-5 text-left">
                                        Password
                                    </th>

                                    <th class="p-5 text-left">
                                        Credits
                                    </th>

                                    <th class="p-5 text-left">
                                        Status
                                    </th>

                                    <th class="p-5 text-center">
                                        Action
                                    </th>

                                </tr>

                            </thead>

                            <tbody class="divide-y divide-white/5">

                                <% users.forEach(u=> { %>

                                    <tr class="hover:bg-white/[0.02] transition-all">

                                        <td class="p-5 text-left">

                                            <div class="font-bold text-white">

                                                <%= u.full_name %>

                                            </div>

                                        </td>

                                        <td class="p-5 text-left text-gray-400">
                                            <%= u.mobile %>
                                        </td>

                                        <td class="p-5 text-left text-gray-400">
                                            <%= u.email %>
                                        </td>

                                        <td class="p-5 text-left text-gray-400">
                                            <%= u.plain_password %>
                                        </td>

                                        <td class="p-5 text-left text-cyan-400 font-bold">

                                            🪙
                                            <%= u.wallet_credits %>

                                        </td>

                                        <td class="p-5 text-center">

                                            <% if(u.status==1) { %>

                                                <span
                                                    class="bg-green-500/10 text-green-400 border border-green-500/20 px-4 py-2 rounded-full text-xs font-bold">

                                                    Active
                                                </span>

                                                <% } else { %>

                                                    <span
                                                        class="bg-red-500/10 text-red-400 border border-red-500/20 px-4 py-2 rounded-full text-xs font-bold">

                                                        Inactive
                                                    </span>

                                                    <% } %>

                                        </td>

                                        <td class="p-5 text-center">

                                            <div class="flex items-center justify-center gap-2">

                                                <form action="/admin/update-user-status" method="POST">

                                                    <input type="hidden" name="user_id" value="<%= u.id %>">

                                                    <input type="hidden" name="status"
                                                        value="<%= u.status == 1 ? 2 : 1 %>">

                                                    <button type="submit" class="<%= u.status == 1
            ? 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'
            : 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20'
        %> border px-4 py-2 rounded-xl text-xs font-bold transition">

                                                        <%= u.status==1 ? 'Block' : 'Activate' %>

                                                    </button>

                                                </form>


                                                <!-- Add Wallet -->
                                                <button
                                                    onclick="openWalletModal('<%= u.id %>', '<%= u.full_name %>', '<%= u.wallet_credits %>')"
                                                    class="bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 px-4 py-2 rounded-xl text-xs font-bold text-green-400 transition">

                                                    + Wallet
                                                </button>

                                                <!-- Minus Wallet -->
                                                <button
                                                    onclick="openWalletModal('<%= u.id %>', '<%= u.full_name %>', '<%= u.wallet_credits %>', 'deduct')"
                                                    class="bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 px-4 py-2 rounded-xl text-xs font-bold text-red-400 transition">

                                                    - Wallet
                                                </button>

                                            </div>

                                        </td>

                                    </tr>

                                    <% }) %>

                            </tbody>

                        </table>

                    </div>

                </div>

            </main>

    </div>

    <!-- Wallet Modal -->
    <div id="walletModal" class="hidden fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-4">

        <div class="bg-[#111] border border-white/10 rounded-3xl p-8 w-full max-w-md">

            <div class="flex justify-between items-center mb-6">

                <h2 class="text-xl font-bold text-white">
                    Update Wallet
                </h2>

                <button onclick="closeWalletModal()" class="text-gray-400 hover:text-red-400 text-2xl">
                    ×
                </button>

            </div>

            <form action="/admin/update-wallet" method="POST">

                <input type="hidden" name="user_id" id="walletUserId">
                <input type="hidden" name="action_type" id="walletActionType">

                <div class="mb-4">
                    <label class="text-xs text-gray-400">
                        User
                    </label>

                    <input type="text" id="walletUserName" readonly
                        class="w-full mt-2 bg-black border border-white/10 rounded-xl p-4 text-white">
                </div>

                <div class="mb-4">
                    <label class="text-xs text-gray-400">
                        Current Wallet
                    </label>

                    <input type="text" id="walletCurrent" readonly
                        class="w-full mt-2 bg-black border border-white/10 rounded-xl p-4 text-cyan-400">
                </div>

                <div class="mb-6">
                    <label class="text-xs text-gray-400">
                        Amount
                    </label>

                    <input type="number" name="amount" required min="1" placeholder="Enter amount"
                        class="w-full mt-2 bg-black border border-white/10 rounded-xl p-4 text-white">
                </div>

                <button type="submit" class="w-full bg-red-600 hover:bg-red-700 py-4 rounded-xl font-bold uppercase">

                    Update Wallet

                </button>

            </form>

        </div>

    </div>

    <script>
        function openWalletModal(id, name, wallet, type = 'add') {

            document.getElementById('walletUserId').value = id;
            document.getElementById('walletUserName').value = name;
            document.getElementById('walletCurrent').value = wallet;
            document.getElementById('walletActionType').value = type;

            document.getElementById('walletModal').classList.remove('hidden');
        }

        function closeWalletModal() {
            document.getElementById('walletModal').classList.add('hidden');
        }
    </script>