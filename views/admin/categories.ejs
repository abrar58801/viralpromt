<%- include('header') %>

    <div class="flex flex-col md:flex-row min-h-screen bg-black">
        <%- include('sidebar') %>

            <main class="flex-1 p-6 md:p-10">

                <div class="flex justify-between items-center mb-8">
                    <h1 class="text-2xl font-bold text-white uppercase">
                        Manage <span class="text-red-500">Categories</span>
                    </h1>

                    <a href="/admin/add-category"
                        class="bg-red-600 hover:bg-red-700 px-6 py-3 rounded-2xl font-bold uppercase">
                        + Add Category
                    </a>
                </div>

                <form method="GET" action="/admin/categories" class="mb-8">

                    <div class="relative">

                        <input type="text" name="search" value="<%= search %>" placeholder="Search categories..."
                            class="w-full bg-[#111] border border-white/10 rounded-2xl px-6 py-4 text-white outline-none focus:border-red-500 transition-all">

                        <button type="submit"
                            class="absolute right-3 top-1/2 -translate-y-1/2 bg-red-600 hover:bg-red-700 px-5 py-2 rounded-xl text-sm font-bold transition">

                            Search

                        </button>

                    </div>

                </form>

                <div class="bg-[#111] rounded-2xl border border-white/5 overflow-hidden">
                    <table class="w-full">
                        <thead>
                            <tr class="text-gray-500">
                                <th class="p-5 text-left">Name</th>
                                <th class="p-5 text-left">Status</th>
                                <th class="p-5 text-left">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% categories.forEach(c=> { %>
                                <tr>
                                    <td class="p-5 text-white">
                                        <%= c.name %>
                                    </td>

                                    <td class="p-5">
                                        <% if(c.status==1) { %>
                                            <span class="text-green-400">Active</span>
                                            <% } else { %>
                                                <span class="text-red-400">Inactive</span>
                                                <% } %>
                                    </td>

                                    <td class="p-5 flex gap-3">
                                        <a href="/admin/edit-category/<%= c.id %>"
                                            class="px-4 py-2 bg-cyan-500/20 rounded-xl text-cyan-400">
                                            Edit
                                        </a>

                                        <button onclick="deleteCategory('<%= c.id %>')"
                                            class="px-4 py-2 bg-red-500/20 rounded-xl text-red-400">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>

            </main>
    </div>

    <script>
        function deleteCategory(id) {
            if (confirm('Delete this category?')) {
                window.location.href = '/admin/delete-category/' + id;
            }
        }
    </script>