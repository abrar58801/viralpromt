<%- include('partials/header') %>

    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="glass-card w-full max-w-md p-8">
            <h2 class="text-3xl font-bold text-center mb-6">Create <span class="text-cyan-400">Account</span></h2>

            <form action="/register" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Full Name</label>
                    <input type="text" name="full_name" required
                        class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none transition">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Email ID</label>
                        <input type="email" name="email" required
                            class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none">
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Mobile No</label>
                        <input type="tel" name="mobile" maxlength="10" pattern="[0-9]{10}" required
                            class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none">
                    </div>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">City</label>
                    <input type="text" name="city" required
                        class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none">
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Password</label>
                    <input type="password" name="password" required
                        class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none">
                </div>

                <div>
                    <label class="block text-xs text-gray-400 mb-1">
                        Refer Code
                    </label>

                    <input type="text" name="referred_by" value="<%= typeof ref !== 'undefined' ? ref : '' %>"
                        placeholder="Enter referral code"
                        class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none">

                </div>

                <button type="submit" class="btn-neon w-full mt-4 py-3">Register Now</button>
            </form>

            <p class="text-center text-sm mt-6 text-gray-500">
                Already have an account? <a href="/login" class="text-cyan-400 underline">Login</a>
            </p>
        </div>
    </div>

    <%- include('partials/footer') %>