<%- include('partials/header') %>

    <div class="min-h-screen bg-[#070707] text-white px-4 py-10">

        <div class="max-w-6xl mx-auto">

            <!-- Main Card -->
            <div
                class="grid grid-cols-1 lg:grid-cols-2 gap-10 bg-[#111] border border-white/5 rounded-[32px] overflow-hidden shadow-2xl">

                <!-- ====================== -->
                <!-- MEDIA SECTION -->
                <!-- ====================== -->

                <div class="p-6 md:p-8">

                    <!-- Type Badge -->
                    <div class="flex items-center justify-between mb-5">

                        <div class="px-4 py-2 rounded-full text-xs font-black tracking-[2px] uppercase border

                        <%= prompt.type === 'video'
                            ? 'bg-purple-500/10 text-purple-400 border-purple-500/20'
                            : 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20' %>">

                            <%= prompt.type==='video' && prompt.media_type==='video' ? 'Video' : 'Image' %> Prompt

                        </div>

                        <div class="text-xs text-gray-500">

                            👁️
                            <%= prompt.fake_views || 0 %>

                        </div>

                    </div>

                    <!-- ====================== -->
                    <!-- IMAGE PROMPT -->
                    <!-- ====================== -->

                    <% if(prompt.type==='image' || (prompt.type==='video' && prompt.media_type==='image' )) { %>

                        <% if(isUnlocked) { %>

                            <div
                                class="relative rounded-3xl overflow-hidden border border-cyan-500/30 shadow-[0_0_40px_rgba(0,255,255,0.08)]">

                                <img src="/uploads/<%= prompt.after_image %>" class="w-full h-[500px] object-cover">

                                <!-- Overlay -->
                                <div
                                    class="absolute top-4 left-4 bg-cyan-500 text-black px-4 py-2 rounded-full text-xs font-black tracking-[2px]">

                                    HD UNLOCKED

                                </div>

                            </div>

                            <p class="text-cyan-400 text-center mt-5 text-sm font-bold">

                                ✨ ORIGINAL IMAGE UNLOCKED

                            </p>

                            <% } else { %>

                                <div class="relative rounded-3xl overflow-hidden border border-white/10">

                                    <img src="/uploads/<%= prompt.before_image %>"
                                        class="w-full h-[500px] object-cover blur-sm scale-105">

                                    <!-- Lock -->
                                    <div class="absolute inset-0 bg-black/40 flex flex-col items-center justify-center">

                                        <div
                                            class="w-20 h-20 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center text-4xl mb-5">

                                            🔒

                                        </div>

                                        <h3 class="text-2xl font-black mb-2">

                                            Locked Preview

                                        </h3>

                                        <p class="text-gray-400 text-sm">

                                            Unlock to view HD image

                                        </p>

                                    </div>

                                </div>

                                <% } %>

                                    <% } %>

                                        <!-- ====================== -->
                                        <!-- VIDEO PROMPT -->
                                        <!-- ====================== -->

                                        <!-- VIDEO PROMPT -->
<% if(prompt.type === 'video' && prompt.media_type === 'video') { %>

    <% if(isUnlocked) { %>

        <div
            class="relative rounded-3xl overflow-hidden border border-purple-500/30 shadow-[0_0_40px_rgba(168,85,247,0.08)]">

            <video
                src="<%= prompt.after_video %>"
                controls
                autoplay
                muted
                playsinline
                class="w-full h-[500px] object-cover bg-black">
            </video>

            <div
                class="absolute top-4 left-4 bg-purple-500 text-white px-4 py-2 rounded-full text-xs font-black tracking-[2px]">

                VIDEO UNLOCKED

            </div>

        </div>

        <p class="text-purple-400 text-center mt-5 text-sm font-bold">
            🎬 ORIGINAL VIDEO UNLOCKED
        </p>

    <% } else { %>

        <div class="relative rounded-3xl overflow-hidden border border-white/10">

            <video
                src="<%= prompt.before_video %>"
                autoplay
                muted
                loop
                playsinline
                class="w-full h-[500px] object-cover blur-sm scale-105 bg-black">
            </video>

            <div class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center">

                <div
                    class="w-20 h-20 rounded-full bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-4xl mb-5">

                    🎬

                </div>

                <h3 class="text-2xl font-black mb-2">
                    Locked Video
                </h3>

                <p class="text-gray-400 text-sm">
                    Unlock to watch full HD video
                </p>

            </div>

        </div>

    <% } %>

<% } %>

                </div>

                <!-- ====================== -->
                <!-- INFO SECTION -->
                <!-- ====================== -->

                <div class="p-6 md:p-10 flex flex-col justify-center">

                    <!-- Category -->
                    <div class="text-cyan-400 text-xs uppercase tracking-[3px] font-black mb-3">

                        <%= prompt.category %>

                    </div>

                    <!-- Title -->
                    <h1 class="text-4xl md:text-5xl font-black leading-tight mb-5">

                        <%= prompt.title %>

                    </h1>

                    <!-- Description -->
                    <p class="text-gray-400 leading-8 text-sm mb-8">

                        Premium AI viral prompt specially crafted
                        for next-generation creators.

                    </p>

                    <!-- ====================== -->
                    <!-- UNLOCKED -->
                    <!-- ====================== -->

                    <% if(isUnlocked) { %>

                        <!-- Prompt -->
                        <div class="bg-black/50 border border-cyan-500/10 rounded-3xl p-6 mb-6">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-cyan-400 text-xs uppercase tracking-[3px] font-black">
                                    Prompt Content
                                </h3>
                                <button onclick="copyPrompt()"
                                    class="bg-cyan-500 text-black px-4 py-2 rounded-xl text-xs font-black">

                                    COPY
                                </button>
                            </div>
                            <code id="promptText"
                                class="text-sm text-gray-200 whitespace-pre-wrap leading-7"><%= prompt.description %></code>
                        </div>

                        <!-- Prompt -->
                        <div class="bg-black/50 border border-cyan-500/10 rounded-3xl p-6 mb-6">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-cyan-400 text-xs uppercase tracking-[3px] font-black">
                                    How To Use
                                </h3>
                            </div>
                            <code
                                class="text-sm text-gray-200 whitespace-pre-wrap leading-7"><%= prompt.how_to_use %></code>
                        </div>

                        <!-- Success -->
                        <div
                            class="bg-green-500/10 border border-green-500/20 text-green-400 rounded-2xl p-5 font-bold text-sm">
                            ✅ Successfully unlocked.
                        </div>

                        <% } else { %>

                            <!-- Price Card -->
                            <div class="bg-red-500/10 border border-red-500/20 rounded-3xl p-8 text-center">

                                <div class="text-6xl mb-5">

                                    🪙

                                </div>

                                <h2 class="text-5xl font-black mb-3">

                                    <%= prompt.price_credits %>

                                </h2>

                                <p class="text-gray-400 text-sm mb-8 uppercase tracking-[3px]">

                                    Credits Required

                                </p>

                                <!-- Unlock -->
                                <form action="/unlock-prompt" method="POST">

                                    <input type="hidden" name="prompt_id" value="<%= prompt.id %>">

                                    <button type="submit"
                                        class="w-full bg-red-600 hover:bg-red-700 py-5 rounded-2xl font-black uppercase tracking-[3px] transition-all active:scale-95 shadow-lg shadow-red-500/20">

                                        Unlock Now

                                    </button>

                                </form>

                            </div>

                            <% } %>

                </div>

            </div>

        </div>

    </div>

    <script>

        function copyPrompt() {

            const text =
                document.getElementById(
                    'promptText'
                ).innerText;

            navigator.clipboard
                .writeText(text);

            alert(
                'Prompt copied!'
            );
        }

    </script>

    <%- include('partials/footer') %>