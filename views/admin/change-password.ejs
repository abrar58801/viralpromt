<%- include('header') %>

<div class="flex flex-col md:flex-row min-h-screen bg-black text-white">

    <%- include('sidebar') %>

    <main class="flex-1 p-6 md:p-10">

        <div class="max-w-2xl mx-auto">

            <h1 class="text-3xl font-black mb-8">
                ⚙️ <span class="text-red-500">Change Password</span>
            </h1>

            <div
                class="bg-[#111] border border-white/10 rounded-3xl p-8">

                <form
                    action="/admin/change-password"
                    method="POST"
                    class="space-y-6">

                    <div>
                        <label class="text-xs text-gray-400">
                            Current Password
                        </label>

                        <input
                            type="password"
                            name="current_password"
                            required
                            class="w-full mt-2 bg-black border border-white/10 rounded-2xl p-4 text-white outline-none">
                    </div>

                    <div>
                        <label class="text-xs text-gray-400">
                            New Password
                        </label>

                        <input
                            type="password"
                            name="new_password"
                            required
                            class="w-full mt-2 bg-black border border-white/10 rounded-2xl p-4 text-white outline-none">
                    </div>

                    <div>
                        <label class="text-xs text-gray-400">
                            Confirm Password
                        </label>

                        <input
                            type="password"
                            name="confirm_password"
                            required
                            class="w-full mt-2 bg-black border border-white/10 rounded-2xl p-4 text-white outline-none">
                    </div>

                    <button
                        type="submit"
                        class="w-full bg-red-600 hover:bg-red-700 py-4 rounded-2xl font-bold uppercase">

                        Update Password

                    </button>

                </form>

            </div>

        </div>

    </main>

</div>