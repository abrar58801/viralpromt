<%- include('header') %>

<div class="flex flex-col md:flex-row min-h-screen bg-black">

    <%- include('sidebar') %>

    <main class="flex-1 p-6 md:p-10">

        <h1
            class="text-2xl font-bold mb-8 text-white uppercase tracking-tighter">

            Contact
            <span class="text-red-500">
                Messages
            </span>

        </h1>

        <div
            class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <% messages.forEach(msg => { %>

                <div
                    class="bg-[#111] border border-white/5 rounded-2xl p-6">

                    <div
                        class="flex items-center justify-between mb-4">

                        <div>

                            <h3
                                class="font-bold text-white">
                                <%= msg.name %>
                            </h3>

                            <p
                                class="text-sm text-gray-500">
                                <%= msg.email %>
                            </p>

                            <p
                                class="text-sm text-gray-500">
                                <%= msg.phone %>
                            </p>

                        </div>

                    </div>

                    <p
                        class="text-gray-300 leading-7">

                        <%= msg.message %>

                    </p>

                </div>

            <% }) %>

        </div>

    </main>

</div>