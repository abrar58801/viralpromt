
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">

<div class="min-h-screen flex items-center justify-center bg-[#050505] px-4">
    <div class="glass-card w-full max-w-sm p-8 border border-red-500/20 shadow-[0_0_50px_rgba(220,38,38,0.1)]">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-black text-white tracking-tighter italic">ADMIN <span class="text-red-500">PANEL</span></h2>
            <p class="text-[10px] text-gray-500 uppercase tracking-[3px] mt-1">Authorized Personnel Only</p>
        </div>
        
        <!-- Form action must be /admin/login because of the prefix we set -->
        <form action="/admin/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-[10px] text-gray-400 mb-2 uppercase font-bold tracking-widest">Admin Username</label>
                <input type="text" name="username" placeholder="Username" required 
                    class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-red-500 outline-none transition-all">
            </div>

            <div>
                <label class="block text-[10px] text-gray-400 mb-2 uppercase font-bold tracking-widest">Admin Password</label>
                <input type="password" name="password" placeholder="••••••••" required 
                    class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-red-500 outline-none transition-all">
            </div>
            
            <div class="pt-2">
                <button type="submit" class="w-full bg-red-600 hover:bg-red-700 py-4 rounded-xl font-black text-xs tracking-[2px] text-white transition-all shadow-[0_10px_20px_rgba(220,38,38,0.2)] active:scale-95">
                    AUTHENTICATE SYSTEM
                </button>
            </div>
        </form>

        <p class="text-center text-[9px] text-gray-600 mt-8 uppercase tracking-widest">
            Viral Prompt v2.0 &bull; Secure Encrypted Connection
        </p>
    </div>
</div>