<%- include('header') %>

    <div class="flex flex-col md:flex-row min-h-screen bg-black">

        <%- include('sidebar') %>

            <main class="flex-1 p-6 md:p-10">

                <!-- Header -->
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">

                    <div>

                        <h1 class="text-2xl font-bold text-white uppercase tracking-tighter">

                            Manage
                            <span class="text-red-500">
                                Prompts
                            </span>

                        </h1>

                        <p class="text-gray-500 mt-2 text-sm">

                            Search, edit and manage prompts.

                        </p>

                    </div>

                    <!-- Add Button -->
                    <a href="/admin/add-prompt"
                        class="bg-red-600 hover:bg-red-700 px-6 py-3 rounded-2xl font-bold uppercase tracking-widest text-sm transition">

                        + Add Prompt
                    </a>

                </div>

                <!-- Search -->
                <form method="GET" action="/admin/prompts" class="mb-8">

                    <div class="relative">

                        <input type="text" name="search" value="<%= search %>" placeholder="Search prompts..."
                            class="w-full bg-[#111] border border-white/10 rounded-2xl px-6 py-4 text-white outline-none focus:border-red-500 transition-all">

                        <button type="submit"
                            class="absolute right-3 top-1/2 -translate-y-1/2 bg-red-600 hover:bg-red-700 px-5 py-2 rounded-xl text-sm font-bold transition">

                            Search
                        </button>

                    </div>

                </form>

                <!-- Table -->
                <div class="bg-[#111] rounded-2xl border border-white/5 overflow-hidden">

                    <div class="overflow-x-auto">

                        <table class="w-full text-left">

                            <thead class="bg-white/5 text-[10px] uppercase text-gray-500 tracking-widest">

                                <tr>

                                    <th class="p-5">
                                        Preview
                                    </th>

                                    <th class="p-5">
                                        Title
                                    </th>

                                    <th class="p-5">
                                        Type
                                    </th>

                                    <th class="p-5">
                                        Price
                                    </th>

                                    <th class="p-5">
                                        Views
                                    </th>

                                    <th class="p-5">
                                        Actions
                                    </th>

                                </tr>

                            </thead>

                            <tbody class="divide-y divide-white/5">

                                <% prompts.forEach(p=> { %>

                                    <tr class="hover:bg-white/[0.02] transition-all">

                                        <!-- Preview -->
                                        <td class="p-5">

                                            <!-- IMAGE -->
                                            <% if(p.type==='image' ) { %>

                                                <div
                                                    class="relative w-16 h-16 rounded-xl overflow-hidden border border-white/10 bg-black">

                                                    <img src="/uploads/<%= p.before_image %>"
                                                        class="w-full h-full object-cover">

                                                    <!-- Badge -->
                                                    <div
                                                        class="absolute bottom-1 left-1 bg-cyan-500 text-black text-[8px] px-2 py-[2px] rounded-full font-black uppercase">

                                                        IMG

                                                    </div>

                                                </div>

                                                <% } %>

                                                    <!-- VIDEO -->
                                                    <% if(p.type==='video' ) { %>

                                                        <div
                                                            class="relative w-16 h-16 rounded-xl overflow-hidden border border-purple-500/20 bg-black">

                                                            <video src="<%= p.before_video %>" muted autoplay loop
                                                                playsinline class="w-full h-full object-cover">
                                                            </video>

                                                            <!-- Play -->
                                                            <div
                                                                class="absolute inset-0 flex items-center justify-center bg-black/20">

                                                                <div
                                                                    class="w-7 h-7 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white text-xs">

                                                                    ▶

                                                                </div>

                                                            </div>

                                                            <!-- Badge -->
                                                            <div
                                                                class="absolute bottom-1 left-1 bg-purple-500 text-white text-[8px] px-2 py-[2px] rounded-full font-black uppercase">

                                                                VID

                                                            </div>

                                                        </div>

                                                        <% } %>

                                        </td>

                                        <!-- Title -->
                                        <td class="p-5 text-white font-bold text-sm">

                                            <%= p.title %>

                                        </td>

                                        <!-- Type -->
                                        <td class="p-5">

                                            <span class="<%= p.type === 'image'
                                        ? 'text-cyan-400'
                                        : 'text-yellow-400' %> text-xs uppercase font-bold">

                                                <%= p.type %>

                                            </span>

                                        </td>

                                        <!-- Price -->
                                        <td class="p-5 text-cyan-400 font-black text-sm">

                                            <%= p.price_credits %> 🪙

                                        </td>

                                        <!-- Views -->
                                        <td class="p-5 text-gray-400 text-sm">

                                            👁️
                                            <%= p.fake_views %>

                                        </td>

                                        <!-- Actions -->
                                        <td class="p-5">

                                            <div class="flex items-center gap-3">

                                                <!-- Edit -->
                                                <a href="/admin/edit-prompt/<%= p.id %>"
                                                    class="px-4 py-2 rounded-xl bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-500/20 text-cyan-400 text-[11px] font-bold uppercase tracking-widest transition">

                                                    Edit
                                                </a>

                                                <!-- Delete -->
                                                <button onclick="deletePrompt('<%= p.id %>')"
                                                    class="px-4 py-2 rounded-xl bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 text-[11px] font-bold uppercase tracking-widest transition">

                                                    Delete
                                                </button>

                                            </div>

                                        </td>

                                    </tr>

                                    <% }) %>

                            </tbody>

                        </table>

                    </div>

                </div>

                <!-- Pagination -->
                <% if(totalPages> 1) { %>

                    <div class="mt-10 flex justify-center items-center gap-4">

                        <!-- Prev -->
                        <% if(currentPage> 1) { %>

                            <a href="/admin/prompts?page=<%= currentPage - 1 %>&search=<%= search %>"
                                class="px-5 py-2 border border-white/10 rounded-xl hover:bg-white/5 transition">

                                ← Back
                            </a>

                            <% } %>

                                <!-- Count -->
                                <div class="px-5 py-2 rounded-xl bg-red-600 text-white font-bold">

                                    <%= currentPage %> / <%= totalPages %>

                                </div>

                                <!-- Next -->
                                <% if(currentPage < totalPages) { %>

                                    <a href="/admin/prompts?page=<%= currentPage + 1 %>&search=<%= search %>"
                                        class="px-5 py-2 border border-white/10 rounded-xl hover:bg-white/5 transition">

                                        Next →
                                    </a>

                                    <% } %>

                    </div>

                    <% } %>

            </main>

    </div>

    <script>

        function deletePrompt(id) {

            const confirmDelete = confirm(
                'Are you sure you want to delete this prompt?'
            );

            if (!confirmDelete) return;

            window.location.href =
                '/admin/delete-prompt/' + id;
        }

    </script>