<%- include('partials/header') %>

<div class="min-h-screen flex items-center justify-center px-4">
    <div class="glass-card w-full max-w-sm p-8">
        <h2 class="text-3xl font-bold text-center mb-6">User <span class="text-cyan-400">Login</span></h2>
        
        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-xs text-gray-400 mb-1">Email Address</label>
                <input type="email" name="email" required class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none">
            </div>
            <div>
                <label class="block text-xs text-gray-400 mb-1">Password</label>
                <input type="password" name="password" required class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-2 focus:border-cyan-400 outline-none">
            </div>
            <div class="text-right">
                <a href="/forgot-password" class="text-[10px] text-cyan-400 hover:underline">Forgot Password?</a>
            </div>
            
            <button type="submit" class="btn-neon w-full mt-2 py-3">Secure Login</button>
        </form>
        
        <p class="text-center text-sm mt-6 text-gray-500">
            New here? <a href="/register" class="text-cyan-400 underline">Create Account</a>
        </p>
    </div>
</div>

<%- include('partials/footer') %>